rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lock instants are hardcoded so picks-locking is enforced server-side.
    // Verified 2026-06-09 (ESPN + Sky Sports):
    //   opener Mexico–South Africa June 11, 13:00 Mexico City = 19:00 UTC
    //   first Round-of-32 match June 28, 8pm UK = 19:00 UTC (re-verify before v2.0)
    // Changing these requires: edit + `firebase deploy --only firestore:rules`
    function groupLock()   { return timestamp.date(2026, 6, 11) + duration.value(19, 'h'); }
    function bracketLock() { return timestamp.date(2026, 6, 28) + duration.value(19, 'h'); }

    function signedIn() { return request.auth != null; }
    // Admin-granted late-pick exception: a pickGrace/{uid} doc with a future
    // `until` lets ONLY that user write group picks after the global lock.
    // Everyone without such a doc stays locked. Admin writes pickGrace (or the
    // results bot's admin SDK, which bypasses rules entirely).
    function groupGrace(uid) {
      return exists(/databases/$(database)/documents/pickGrace/$(uid))
             && request.time < get(/databases/$(database)/documents/pickGrace/$(uid)).data.until;
    }
    // Admin is gated by verified Google email — must match ADMIN_EMAIL in src/App.jsx.
    function isAdmin() {
      return signedIn()
             && request.auth.token.email == 'tac02189@gmail.com'
             && request.auth.token.email_verified == true;
    }
    // Optional membership gate: to close the pool to invited people only,
    // replace signedIn() with isMember() everywhere below and list the
    // family's Google emails here, then `firebase deploy --only firestore:rules`.
    // function isMember() {
    //   return signedIn() && request.auth.token.email in [
    //     'tac02189@gmail.com'
    //   ];
    // }

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Own picks: read/write any time before lock. Others' picks: readable only
    // after lock. Shape checks: the thirds cap matters — scoring counts every
    // matching entry, so an uncapped array would be a score-inflation vector.
    match /groupPicks/{uid} {
      allow read: if signedIn()
                  && (request.auth.uid == uid || request.time > groupLock() || isAdmin());
      allow write: if signedIn() && request.auth.uid == uid
                  && (request.time < groupLock() || groupGrace(uid))
                  && request.resource.data.keys().hasOnly(['groups', 'thirds', 'updatedAt'])
                  && request.resource.data.groups is map
                  && request.resource.data.thirds is list
                  && request.resource.data.thirds.size() <= 8;
    }

    match /bracketPicks/{uid} {
      allow read: if signedIn()
                  && (request.auth.uid == uid || request.time > bracketLock() || isAdmin());
      allow write: if signedIn() && request.auth.uid == uid && request.time < bracketLock()
                  && request.resource.data.keys().hasOnly(['winners', 'champion', 'updatedAt'])
                  && request.resource.data.winners is map;
    }

    // Written by the results bot (admin SDK bypasses rules) or Thiago's admin page.
    match /results/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /config/{doc} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Late-pick grace tokens. A user reads their own to know the UI should stay
    // open; only admin grants/revokes them. Rule get()/exists() above read these
    // regardless of this block.
    match /pickGrace/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // Leagues are admin-created named pools; the doc id IS the share code, so
    // anyone holding a code can get() it to confirm/join, but only admin lists
    // or writes. Membership lives on each user's own doc (users/{uid}.leagues),
    // so members never write here — they edit their own user doc to join/leave.
    match /leagues/{code} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
